{
  "name": "nodejs-omnifocus-bridge",
  "version": "0.1.0",
  "description": "Standalone OmniFocus reader and CLI for local macOS installs and encrypted vaults.",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "engines": {
    "node": ">=20"
  },
  "bin": {
    "omnifocus-list": "./dist/cli/omnifocus-list.js"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "clean": "node -e \"import('node:fs').then((fs) => fs.rmSync('dist', { recursive: true, force: true }))\"",
    "build": "npm run clean && tsc -p tsconfig.json",
    "prepack": "npm run build",
    "test": "vitest run",
    "test:watch": "vitest watch",
    "test:coverage": "vitest run --coverage",
    "cli:list": "tsx src/cli/omnifocus-list.ts"
  },
  "keywords": [
    "omnifocus",
    "typescript",
    "cli",
    "macos"
  ],
  "license": "MIT",
  "homepage": "https://github.com/johannes/nodejs-omnifocus-bridge#readme",
  "bugs": {
    "url": "https://github.com/johannes/nodejs-omnifocus-bridge/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/johannes/nodejs-omnifocus-bridge.git"
  },
  "dependencies": {
    "jszip": "^3.10.1",
    "plist": "^3.1.0",
    "sax": "^1.4.1"
  },
  "devDependencies": {
    "@types/node": "^24.2.1",
    "@vitest/coverage-v8": "^3.2.4",
    "tsx": "^4.20.4",
    "typescript": "^5.9.2",
    "vitest": "^3.2.4"
  }
}
